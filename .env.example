# --- Database ---
DATABASE_URL="postgresql://chess:chess@localhost:5432/chess?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
ACCESS_TTL="15m"
REFRESH_TTL="30d"

# --- Google OAuth (optional in this slice) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Server ---
PORT=3000
WEB_ORIGIN="http://localhost:5173"

# --- Wallet (reserved for the wallet phase) ---
# Tokens credited to a new account on signup (play-money).
SIGNUP_GRANT=1000
# Platform fee on winnings, in basis points. 100 = 1%, 10 = 0.1%, 1 = 0.01%.
PLATFORM_FEE_BPS=10

# --- Frontend (Vite) ---
# Optional. Leave unset to auto-derive the API URL from the browser location
# (works on localhost and GitHub Codespaces). Set it only to pin a custom API.
# VITE_API_URL="http://localhost:3000"

# --- Server CORS ---
# Optional. Leave unset to reflect the request origin (Codespaces-friendly).
# Set to your web origin in production, e.g. https://app.example.com
# WEB_ORIGIN="http://localhost:5173"
